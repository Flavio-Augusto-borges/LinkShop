# Compose-level variables for the first controlled external deploy.
# Copy to .env.deploy and adjust for your target environment.

# Backend image/tag used by docker-compose.prod.yml.
# Keep tags immutable so rollback is predictable.
BACKEND_IMAGE=linkshop-backend:2026-04-07

# Backend env file mounted by compose.
BACKEND_ENV_FILE=backend/.env.production

# Runtime ports
BACKEND_PORT=8000
POSTGRES_PORT=5432

# Startup behavior
RUN_MIGRATIONS_ON_STARTUP=false

# If you choose the "with-db" profile in compose
POSTGRES_DB=linkshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
